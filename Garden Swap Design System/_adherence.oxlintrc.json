{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/plants/**",
              "ui_kits/garden_swap_app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|Newsreader))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, Newsreader."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:swap|free|type|condition|rarity|pending|accepted|completed|declined)$/]",
        "message": "<Badge> variant must be one of 'swap' | 'free' | 'type' | 'condition' | 'rarity' | 'pending' | 'accepted' | 'completed' | 'declined'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|full|pill|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, full, pill, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|danger|steward|outline|text)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'danger' | 'steward' | 'outline' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|interactive|padded|bordered|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, interactive, padded, bordered, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|fill|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, fill, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|optional|variant|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, optional, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|search)$/]",
        "message": "<Input> variant must be one of 'default' | 'search'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlantCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|status|plantType|rarity|distance|lister|rating|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PlantCard> doesn't accept that prop. Declared props: image, title, status, plantType, rarity, distance, lister, rating, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlantCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:swap|free)$/]",
        "message": "<PlantCard> status must be one of 'swap' | 'free'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|size|style|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, size, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Select> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|count|interactive|size|onChange|style|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, count, interactive, size, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StarRating> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TierBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|showGlyph|style|key|ref|className|style|children)$/]",
        "message": "<TierBadge> doesn't accept that prop. Declared props: tier, showGlyph, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TierBadge'] > JSXAttribute[name.name='tier'] > Literal[value!=/^(?:sprout|grower|steward)$/]",
        "message": "<TierBadge> tier must be one of 'sprout' | 'grower' | 'steward'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
